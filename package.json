{
  "name": "learnsmart",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"var f=require('path').join(process.cwd(),'frontend','.next','dev','lock');try{require('fs').rmSync(f,{recursive:true,force:true})}catch(e){}\"",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "cd api && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd api && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
